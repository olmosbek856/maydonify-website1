# ────────────────────────────────────────────────────────────────────
# Maydonify — Environment Variables
# Copy this file to .env.local for local development
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# ────────────────────────────────────────────────────────────────────

# Telegram Bot — for owner form notifications
# How to get these:
#   1. Message @BotFather on Telegram → /newbot → copy the token
#   2. Add the bot to your group/channel → send a message
#   3. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#   4. Find "chat":{"id": ...} — that is your TELEGRAM_CHAT_ID
#
# If left empty, form submissions will only appear in Vercel function logs.

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
